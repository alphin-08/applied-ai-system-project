classDiagram
    class Owner {
        +String name
        +String email
        +List~Pet~ pets
        +add_pet(pet)
        +get_pets()
        +get_pet_by_name(name)
    }

    class Pet {
        +String name
        +String species
        +int age
        +String health_notes
        +List~CareTask~ tasks
        +add_task(task)
        +get_tasks()
        +get_tasks_by_status(completed)
        +complete_task(task)
        +expand_recurring_tasks(days_ahead)
    }

    class CareTask {
        +String title
        +String task_type
        +int duration_minutes
        +String priority
        +datetime scheduled_time
        +bool completed
        +String recurrence
        +mark_complete()
        +is_due_today()
        +next_occurrence()
        +end_time()
        +conflicts_with(other)
        +__repr__()
    }

    class Scheduler {
        +Owner owner
        +List plan
        +List conflicts
        +build_plan(pet_filter, show_completed)
        +get_next_task()
        +get_tasks_by_time()
        +explain_plan()
        -_detect_conflicts()
    }

    class Retriever {
        <<module>>
        +retrieve_context(pet, task_types) String
    }

    class KnowledgeBase {
        <<module pet_care_kb.py>>
        +SPECIES_GUIDELINES Dict
        +AGE_GUIDELINES Dict
        +TASK_GUIDELINES Dict
        +HEALTH_GUIDELINES Dict
        +age_bracket(species, age) String
    }

    class AIAdvisor {
        <<module ai_advisor.py>>
        +generate_care_advice(pet, plan, conflicts, retrieved_context) String
        -_build_schedule_summary(pet, plan, conflicts) String
        -_model GenerativeModel
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "1" --> "0..*" CareTask : has
    Scheduler "1" --> "1" Owner : schedules for
    CareTask ..> CareTask : next_occurrence()
    Retriever ..> Pet : reads profile
    Retriever ..> KnowledgeBase : looks up
    AIAdvisor ..> Pet : reads profile
    AIAdvisor ..> CareTask : reads schedule
    AIAdvisor ..> Retriever : receives context from
